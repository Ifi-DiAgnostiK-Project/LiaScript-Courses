#!/usr/bin/env python3
"""
Pre-commit hook for course markdown files.

Two things happen automatically before each commit:

1. Relative image links are converted to absolute raw.githubusercontent.com
   URLs pointing to refs/heads/main.  This ensures images display correctly
   when courses are served via tag-based URLs in LiaScript.
   (see scripts/convert_relative_links.py for details)

2. YAML syntax in the course header is validated to catch errors before
   they are committed.

Installation:
    python3 scripts/install-pre-commit-hook.py

Manual installation:
    ln -s ../../scripts/pre-commit .git/hooks/pre-commit
    chmod +x .git/hooks/pre-commit
"""

import sys
import os
import subprocess
from pathlib import Path

# Determine repo root - this script may be run from .git/hooks/ or scripts/
# When run as a hook, __file__ is .git/hooks/pre-commit
# When run directly, __file__ is scripts/pre-commit
SCRIPT_PATH = Path(__file__).resolve()

# Check if we're running from .git/hooks/
if SCRIPT_PATH.parent.name == 'hooks':
    # We're in .git/hooks/, so repo root is two levels up
    REPO_ROOT = SCRIPT_PATH.parent.parent.parent
else:
    # We're in scripts/, so repo root is one level up
    REPO_ROOT = SCRIPT_PATH.parent.parent

# Add scripts directory to path
SCRIPTS_DIR = REPO_ROOT / 'scripts'
sys.path.insert(0, str(SCRIPTS_DIR))

# Import hook helpers
from validate_course_yaml import validate_course_file
from convert_relative_links import convert_file as convert_links


def get_staged_course_files():
    """
    Get list of staged course markdown files.
    
    Returns:
        List of Path objects for staged .md files in courses/
    """
    try:
        # Get list of staged files
        result = subprocess.run(
            ['git', 'diff', '--cached', '--name-only', '--diff-filter=ACM'],
            capture_output=True,
            text=True,
            check=True,
            cwd=REPO_ROOT
        )
        
        staged_files = result.stdout.strip().split('\n')
        
        # Filter for course markdown files
        course_files = []
        for file in staged_files:
            if file.startswith('courses/') and file.endswith('.md'):
                filepath = REPO_ROOT / file
                if filepath.exists():
                    course_files.append(filepath)
        
        return course_files
    except subprocess.CalledProcessError:
        return []


def restage_file(filepath: Path):
    """Re-add a file to the git index after it has been modified in-place."""
    try:
        subprocess.run(
            ['git', 'add', str(filepath)],
            check=True,
            cwd=REPO_ROOT,
        )
    except subprocess.CalledProcessError as e:
        print(f"  ⚠️  Could not re-stage {filepath.name}: {e}", file=sys.stderr)


def main():
    """Main pre-commit hook function."""
    
    # Get staged course files
    course_files = get_staged_course_files()
    
    if not course_files:
        # No course files staged, allow commit
        sys.exit(0)
    
    # ── Step 1: Convert relative image links to absolute URLs ────────────
    print(f"🔗 Converting relative image links in {len(course_files)} staged course file(s)...")
    converted_count = 0
    for filepath in course_files:
        if convert_links(filepath, REPO_ROOT):
            converted_count += 1
            print(f"   ✅ Converted links in {filepath.relative_to(REPO_ROOT)}")
            restage_file(filepath)

    if converted_count == 0:
        print("   (no relative links found)")
    else:
        print(f"   {converted_count} file(s) updated and re-staged")

    # ── Step 2: Validate YAML headers ────────────────────────────────────
    print(f"\n🔍 Validating {len(course_files)} staged course file(s)...")
    
    # Validate each staged file
    has_errors = False
    has_warnings = False
    
    for filepath in course_files:
        result = validate_course_file(filepath)
        
        if not result.success:
            has_errors = True
            print(f"\n❌ {filepath.relative_to(REPO_ROOT)}")
            print(f"   {result.error_message or result.warning_message}")
        elif result.warning_message:
            has_warnings = True
            print(f"\n⚠️  {filepath.relative_to(REPO_ROOT)}")
            print(f"   {result.warning_message}")
    
    # Print summary
    if has_errors:
        print("\n" + "="*70)
        print("❌ COMMIT REJECTED - YAML validation failed")
        print("="*70)
        print("\nFix the errors above and try again.")
        print("Or run: python3 scripts/validate_course_yaml.py --verbose")
        print("\nTo bypass this check (NOT recommended):")
        print("  git commit --no-verify")
        sys.exit(1)
    elif has_warnings:
        print("\n" + "="*70)
        print("⚠️  COMMIT ALLOWED - But warnings found")
        print("="*70)
        print("\nConsider fixing warnings before committing.")
        print("See: docs/YAML_VALIDATION_GUIDE.md")
        sys.exit(0)
    else:
        print("\n✅ All staged course files validated successfully")
        sys.exit(0)


if __name__ == '__main__':
    main()
